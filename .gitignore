# Godot 4+ specific ignores
.godot/
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# System / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Local Godot user data (snapshots, credentials — NEVER commit)
# (user:// maps to %APPDATA%/Godot/app_userdata/Orchestrator on Windows)
# We still guard against accidental check-in if paths are relocated:
credentials.enc
gdd_snapshots/

# Test output
tests/.gut_editor_config.json
.gut_editor_shotgun

# IDE
.vscode/
.idea/
dist/ 
*.exe 
*.dll 
*.pdb 
export_presets.cfg~ 
