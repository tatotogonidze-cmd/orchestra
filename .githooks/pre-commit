#!/usr/bin/env bash
# Orchestra pre-commit hook.
#
# 1. Scans staged files for plaintext credentials.
# 2. Optionally runs the GUT test suite (skipped if $ORCHESTRA_SKIP_TESTS=1 or
#    Godot is not on PATH — fine for quick WIP commits).
#
# Install with:
#   git config core.hooksPath .githooks
#
# On Windows/Git Bash this file works unchanged. On native cmd.exe, invoke via
# Git for Windows' bash wrapper (the default when Git is installed).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- 1. Plaintext-key scan -----------------------------------------------------

if command -v python3 >/dev/null 2>&1; then
  PY=python3
elif command -v python >/dev/null 2>&1; then
  PY=python
else
  echo "pre-commit: no python on PATH, skipping plaintext-key scan" >&2
  PY=""
fi

if [[ -n "$PY" ]]; then
  "$PY" tools/check_plaintext_keys.py || {
    echo "pre-commit: plaintext-key scan failed" >&2
    exit 1
  }
fi

# --- 2. GUT tests (opt-out via env var) ---------------------------------------

if [[ "${ORCHESTRA_SKIP_TESTS:-0}" == "1" ]]; then
  echo "pre-commit: ORCHESTRA_SKIP_TESTS=1, skipping tests"
  exit 0
fi

if ! command -v godot >/dev/null 2>&1; then
  echo "pre-commit: godot not on PATH, skipping tests (set ORCHESTRA_SKIP_TESTS=1 to silence)" >&2
  exit 0
fi

# If addons/gut isn't present yet, don't block the commit — print guidance instead.
if [[ ! -d "addons/gut" ]]; then
  echo "pre-commit: addons/gut not installed, skipping tests. See README for setup." >&2
  exit 0
fi

echo "pre-commit: running GUT tests (headless)..."
godot --headless -s addons/gut/gut_cmdln.gd -gconfig=.gutconfig.json || {
  echo "pre-commit: tests failed" >&2
  exit 1
}

echo "pre-commit: OK"
